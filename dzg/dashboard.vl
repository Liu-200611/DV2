    },
    "padding":  16,
    "spacing":  24,
    "vconcat":  [
                    {
                        "hconcat":  [
                                        {
                                            "title":  "INTRODUCTION: A REGIONAL BURDEN",
                                            "width":  280,
                                            "height":  360,
                                            "layer":  [
                                                          {
                                                              "data":  {
                                                                           "values":  [
                                                                                          {
                                                                                              "x":  0,
                                                                                              "x2":  280,
                                                                                              "y":  0,
                                                                                              "y2":  360
                                                                                          }
                                                                                      ]
                                                                       },
                                                              "mark":  {
                                                                           "type":  "rect",
                                                                           "fill":  "transparent",
                                                                           "stroke":  "#a8a8a8",
                                                                           "strokeDash":  [
                                                                                              6,
                                                                                              6
                                                                                          ],
                                                                           "strokeWidth":  1
                                                                       },
                                                              "encoding":  {
                                                                               "x":  {
                                                                                         "field":  "x",
                                                                                         "type":  "quantitative",
                                                                                         "axis":  null,
                                                                                         "scale":  {
                                                                                                       "domain":  [
                                                                                                                      0,
                                                                                                                      280
                                                                                                                  ]
                                                                                                   }
                                                                                     },
                                                                               "x2":  {
                                                                                          "field":  "x2"
                                                                                      },
                                                                               "y":  {
                                                                                         "field":  "y",
                                                                                         "type":  "quantitative",
                                                                                         "axis":  null,
                                                                                         "scale":  {
                                                                                                       "domain":  [
                                                                                                                      0,
                                                                                                                      360
                                                                                                                  ]
                                                                                                   }
                                                                                     },
                                                                               "y2":  {
                                                                                          "field":  "y2"
                                                                                      }
                                                                           }
                                                          },
                                                          {
                                                              "mark":  {
                                                                           "type":  "text",
                                                                           "align":  "left",
                                                                           "baseline":  "top",
                                                                           "font":  "Inter, \u0027Helvetica Neue\u0027, Arial, sans-serif",
                                                                           "fontSize":  11,
                                                                           "color":  "#333333",
                                                                           "text":  [
                                                                                        "The consumption of tobacco and",
                                                                                        "areca nut is not merely an",
                                                                                        "individual habit; it is a deeply",
                                                                                        "entrenched public health crisis",
                                                                                        "spanning South-East Asia and the",
                                                                                        "Western Pacific. Global data",
                                                                                        "reveals staggering regional",
                                                                                        "prevalence rates, led by Bangladesh",
                                                                                        "at 27.5%, followed closely by India",
                                                                                        "(21.4%), Indonesia (21.0%), and",
                                                                                        "Bhutan (19.7%). Even within the",
                                                                                        "Western Pacific, countries like",
                                                                                        "China present a significant",
                                                                                        "prevalence of 12.9%. These figures",
                                                                                        "highlight a widespread cultural",
                                                                                        "acceptance that masks a severe,",
                                                                                        "ongoing threat to oral health",
                                                                                        "across borders."
                                                                                    ],
                                                                           "dx":  14,
                                                                           "dy":  14
                                                                       },
                                                              "data":  {
                                                                           "values":  [
                                                                                          {

                                                                                          }
                                                                                      ]
                                                                       },
                                                              "encoding":  {
                                                                               "x":  {
                                                                                         "value":  0
                                                                                     },
                                                                               "y":  {
                                                                                         "value":  0
                                                                                     }
                                                                           }
                                                          }
                                                      ]
                                        },
                                        {
                                            "title":  "Prevalence by Country",
                                            "width":  620,
                                            "height":  360,
                                            "data":  {
                                                         "url":  "countries_data.json",
                                                         "format":  {
                                                                        "type":  "topojson",
                                                                        "feature":  "1"
                                                                    }
                                                     },
                                            "projection":  {
                                                               "type":  "mercator",
                                                               "center":  [
                                                                              100,
                                                                              20
                                                                          ],
                                                               "scale":  430
                                                           },
                                            "transform":  [
                                                              {
                                                                  "calculate":  "datum.properties.NAME == \u0027North Korea\u0027 ? \u0027Democratic People\\u2019s Republic of Korea\u0027 : datum.properties.NAME",
                                                                  "as":  "CountryLookupName"
                                                              },
                                                              {
                                                                  "lookup":  "CountryLookupName",
                                                                  "from":  {
                                                                               "data":  {
                                                                                            "url":  "countries_data.csv"
                                                                                        },
                                                                               "key":  "ISO_A3",
                                                                               "fields":  [
                                                                                              "Region",
                                                                                              "Prevalence"
                                                                                          ]
                                                                           }
                                                              },
                                                              {
                                                                  "calculate":  "toNumber(datum.Prevalence)",
                                                                  "as":  "PrevalenceValue"
                                                              }
                                                          ],
                                            "layer":  [
                                                          {
                                                              "mark":  {
                                                                           "type":  "geoshape",
                                                                           "fill":  "#e6e6e6",
                                                                           "stroke":  "#ffffff",
                                                                           "strokeWidth":  0.6
                                                                       }
                                                          },
                                                          {
                                                              "transform":  [
                                                                                {
                                                                                    "filter":  "isValid(datum.PrevalenceValue)"
                                                                                }
                                                                            ],
                                                              "mark":  {
                                                                           "type":  "geoshape",
                                                                           "stroke":  "#ffffff",
                                                                           "strokeWidth":  0.7
                                                                       },
                                                              "encoding":  {
                                                                               "color":  {
                                                                                             "field":  "PrevalenceValue",
                                                                                             "type":  "quantitative",
                                                                                             "title":  "Prevalence",
                                                                                             "scale":  {
                                                                                                           "scheme":  "blues"
                                                                                                       }
                                                                                         },
                                                                               "tooltip":  [
                                                                                               {
                                                                                                   "field":  "properties.NAME",
                                                                                                   "type":  "nominal",
                                                                                                   "title":  "Country"
                                                                                               },
                                                                                               {
                                                                                                   "field":  "Region",
                                                                                                   "type":  "nominal"
                                                                                               },
                                                                                               {
                                                                                                   "field":  "PrevalenceValue",
                                                                                                   "type":  "quantitative",
                                                                                                   "title":  "Prevalence",
                                                                                                   "format":  ".1f"
                                                                                               }
                                                                                           ]
                                                                           }
                                                          }
                                                      ]
                                        }
                                    ]
                    },
                    {
                        "hconcat":  [
                                        {
                                            "title":  "Malaysia Overall Indicators",
                                            "width":  620,
                                            "height":  300,
                                            "data":  {
                                                         "url":  "malasyia_data.csv"
                                                     },
                                            "transform":  [
                                                              {
                                                                  "filter":  "datum.Group == \u0027Overall\u0027"
                                                              },
                                                              {
                                                                  "calculate":  "toNumber(datum[\u0027Value (%)\u0027])",
                                                                  "as":  "Value"
                                                              }
                                                          ],
                                            "mark":  {
                                                         "type":  "arc",
                                                         "innerRadius":  70,
                                                         "outerRadius":  135,
