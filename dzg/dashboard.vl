                                                                           "fontSize":  11,
                                                                           "color":  "#333333",
                                                                           "text":  [
                                                                                        "Occupationally, the highest",
                                                                                        "prevalence is seen among the",
                                                                                        "Employed (4.8%) and",
                                                                                        "Students/Children (4.0%), proving",
                                                                                        "that active, productive segments of",
                                                                                        "society are the most exposed."
                                                                                    ],
                                                                           "dx":  14,
