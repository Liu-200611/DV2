{
    "$schema":  "https://vega.github.io/schema/vega-lite/v5.json",
    "title":  {
                  "text":  "The Silent Epidemic: Tobacco, Areca Nut, and the Looming Oral Health Crisis",
                  "subtitle":  "Regional burden, Malaysia indicators, oral health consequences, and demographic vulnerabilities",
                  "anchor":  "start",
                  "fontSize":  24,
                  "subtitleFontSize":  14,
                  "offset":  14,
                  "font":  "Inter, \u0027Helvetica Neue\u0027, Arial, sans-serif",
                  "color":  "#111111",
                  "subtitleFont":  "Inter, \u0027Helvetica Neue\u0027, Arial, sans-serif",
                  "subtitleColor":  "#555555"
              },
    "background":  "transparent",
    "config": {
      "view": {
        "fill": "transparent",
        "stroke": "transparent"
      },
      "title": {
