                                                                           "legend":  {
                                                                                          "title":  null,
                                                                                          "orient":  "bottom"
                                                                                      },
                                                                           "scale":  {
                                                                                         "scheme":  "blueorange"
                                                                                     }
                                                                       },
                                                             "tooltip":  [
                                                                             {
                                                                                 "field":  "Parameter",
                                                                                 "type":  "nominal"
                                                                             },
                                                                             {
