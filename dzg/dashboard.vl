                                                                                 "title":  "Value (%)",
                                                                                 "format":  ".1f"
                                                                             }
                                                                         ]
                                                         }
                                        },
                                        {
                                            "title":  "THE LOCAL REALITY: MALAYSIA\u0027S DUAL CRISIS",
                                            "width":  280,
                                            "height":  300,
                                            "layer":  [
                                                          {
                                                              "data":  {
                                                                           "values":  [
                                                                                          {
                                                                                              "x":  0,
                                                                                              "x2":  280,
                                                                                              "y":  0,
                                                                                              "y2":  300
                                                                                          }
                                                                                      ]
                                                                       },
                                                              "mark":  {
                                                                           "type":  "rect",
                                                                           "fill":  "transparent",
                                                                           "stroke":  "#a8a8a8",
                                                                           "strokeDash":  [
                                                                                              6,
                                                                                              6
                                                                                          ],
                                                                           "strokeWidth":  1
                                                                       },
                                                              "encoding":  {
                                                                               "x":  {
                                                                                         "field":  "x",
                                                                                         "type":  "quantitative",
                                                                                         "axis":  null,
                                                                                         "scale":  {
                                                                                                       "domain":  [
                                                                                                                      0,
                                                                                                                      280
                                                                                                                  ]
                                                                                                   }
                                                                                     },
                                                                               "x2":  {
                                                                                          "field":  "x2"
                                                                                      },
                                                                               "y":  {
                                                                                         "field":  "y",
                                                                                         "type":  "quantitative",
                                                                                         "axis":  null,
                                                                                         "scale":  {
                                                                                                       "domain":  [
                                                                                                                      0,
                                                                                                                      300
                                                                                                                  ]
                                                                                                   }
                                                                                     },
                                                                               "y2":  {
                                                                                          "field":  "y2"
                                                                                      }
                                                                           }
                                                          },
                                                          {
                                                              "mark":  {
                                                                           "type":  "text",
                                                                           "align":  "left",
                                                                           "baseline":  "top",
                                                                           "font":  "Inter, \u0027Helvetica Neue\u0027, Arial, sans-serif",
                                                                           "fontSize":  11,
                                                                           "color":  "#333333",
                                                                           "text":  [
                                                                                        "When we zoom into Malaysia, the",
                                                                                        "numbers paint a stark and troubling",
                                                                                        "picture of substance dependency.",
                                                                                        "The overall smoking rate stands at",
                                                                                        "a massive 41.7%, while the",
                                                                                        "traditional practice of betel quid",
                                                                                        "chewing is close behind at 37.7%.",
                                                                                        "This heavy dual consumption of",
                                                                                        "smoked tobacco and chewed areca nut",
                                                                                        "inflicts a severe physical toll on",
                                                                                        "the population\u0027s oral health: more",
                                                                                        "than one-fifth of Malaysians",
                                                                                        "(20.3%) suffer from Oral Mucosal",
                                                                                        "Lesions (OML), and an alarming 1.4%",
                                                                                        "exhibit signs of Oral Pre-Cancer",
                                                                                        "(OPC)."
                                                                                    ],
                                                                           "dx":  14,
                                                                           "dy":  14
                                                                       },
                                                              "data":  {
                                                                           "values":  [
                                                                                          {

                                                                                          }
                                                                                      ]
                                                                       },
                                                              "encoding":  {
                                                                               "x":  {
                                                                                         "value":  0
                                                                                     },
                                                                               "y":  {
                                                                                         "value":  0
                                                                                     }
                                                                           }
                                                          }
                                                      ]
                                        }
                                    ]
                    },
                    {
                        "hconcat":  [
                                        {
                                            "title":  "THE TOXIC LINK: QUID CHEWING CONSEQUENCES",
                                            "width":  280,
                                            "height":  320,
                                            "layer":  [
                                                          {
                                                              "data":  {
                                                                           "values":  [
                                                                                          {
                                                                                              "x":  0,
                                                                                              "x2":  280,
                                                                                              "y":  0,
                                                                                              "y2":  320
                                                                                          }
                                                                                      ]
                                                                       },
                                                              "mark":  {
                                                                           "type":  "rect",
                                                                           "fill":  "transparent",
                                                                           "stroke":  "#a8a8a8",
                                                                           "strokeDash":  [
                                                                                              6,
                                                                                              6
                                                                                          ],
                                                                           "strokeWidth":  1
                                                                       },
                                                              "encoding":  {
                                                                               "x":  {
                                                                                         "field":  "x",
                                                                                         "type":  "quantitative",
                                                                                         "axis":  null,
                                                                                         "scale":  {
                                                                                                       "domain":  [
                                                                                                                      0,
                                                                                                                      280
                                                                                                                  ]
                                                                                                   }
                                                                                     },
                                                                               "x2":  {
                                                                                          "field":  "x2"
                                                                                      },
                                                                               "y":  {
                                                                                         "field":  "y",
                                                                                         "type":  "quantitative",
                                                                                         "axis":  null,
                                                                                         "scale":  {
                                                                                                       "domain":  [
                                                                                                                      0,
                                                                                                                      320
                                                                                                                  ]
                                                                                                   }
                                                                                     },
                                                                               "y2":  {
                                                                                          "field":  "y2"
                                                                                      }
                                                                           }
                                                          },
                                                          {
                                                              "mark":  {
                                                                           "type":  "text",
                                                                           "align":  "left",
                                                                           "baseline":  "top",
                                                                           "font":  "Inter, \u0027Helvetica Neue\u0027, Arial, sans-serif",
                                                                           "fontSize":  11,
                                                                           "color":  "#333333",
                                                                           "text":  [
                                                                                        "The direct medical consequence of",
                                                                                        "quid chewing becomes undeniable",
                                                                                        "when comparing user groups. Among",
                                                                                        "those who chew betel quid, the",
                                                                                        "prevalence of Oral Mucosal Lesions",
                                                                                        "skyrockets to 35.6%, compared to",
                                                                                        "just 11.0% among non-chewers. More",
                                                                                        "critically, the risk of developing",
                                                                                        "Oral Pre-Cancerous lesions",
                                                                                        "increases significantly, rising",
                                                                                        "from 1.2% in non-chewers to 1.9%",
                                                                                        "among quid chewers. This clear",
                                                                                        "disparity demonstrates that areca",
                                                                                        "nut use serves as a fast track",
                                                                                        "toward debilitating oral",
                                                                                        "malignancies."
                                                                                    ],
                                                                           "dx":  14,
                                                                           "dy":  14
                                                                       },
                                                              "data":  {
                                                                           "values":  [
                                                                                          {

                                                                                          }
                                                                                      ]
                                                                       },
                                                              "encoding":  {
                                                                               "x":  {
                                                                                         "value":  0
                                                                                     },
                                                                               "y":  {
                                                                                         "value":  0
                                                                                     }
                                                                           }
                                                          }
                                                      ]
                                        },
                                        {
                                            "title":  "OML and OPC Prevalence by Quid Chewing Status",
                                            "data":  {
                                                         "url":  "malasyia_details.csv"
                                                     },
                                            "transform":  [
                                                              {
                                                                  "calculate":  "toNumber(datum[\u0027Value (%)\u0027])",
                                                                  "as":  "Value"
                                                              },
                                                              {
                                                                  "calculate":  "round(datum.Value)",
                                                                  "as":  "FilledCount"
                                                              },
                                                              {
                                                                  "calculate":  "sequence(1, 101)",
                                                                  "as":  "WaffleCells"
                                                              },
                                                              {
                                                                  "flatten":  [
                                                                                  "WaffleCells"
                                                                              ],
                                                                  "as":  [
                                                                             "Cell"
                                                                         ]
                                                              },
                                                              {
                                                                  "calculate":  "(datum.Cell - 1) % 10",
                                                                  "as":  "Column"
                                                              },
                                                              {
                                                                  "calculate":  "9 - floor((datum.Cell - 1) / 10)",
                                                                  "as":  "Row"
                                                              },
                                                              {
                                                                  "calculate":  "datum.Cell \u003c= datum.FilledCount",
                                                                  "as":  "Filled"
                                                              }
                                                          ],
                                            "facet":  {
                                                          "row":  {
                                                                      "field":  "Parameter",
                                                                      "type":  "nominal",
                                                                      "title":  null,
                                                                      "header":  {
                                                                                     "labelAngle":  0,
                                                                                     "labelFontSize":  13,
                                                                                     "labelFontWeight":  "bold"
                                                                                 }
                                                                  },
                                                          "column":  {
                                                                         "field":  "Group",
                                                                         "type":  "nominal",
                                                                         "title":  null,
                                                                         "sort":  [
                                                                                      "Quid Chewers",
                                                                                      "Non-Quid Chewers"
                                                                                  ],
                                                                         "header":  {
                                                                                        "labelFontSize":  13,
                                                                                        "labelFontWeight":  "bold"
                                                                                    }
                                                                     }
                                                      },
                                            "spec":  {
                                                         "width":  105,
                                                         "height":  105,
                                                         "layer":  [
                                                                       {
                                                                           "mark":  {
                                                                                        "type":  "rect",
                                                                                        "cornerRadius":  2,
                                                                                        "stroke":  "#ffffff",
                                                                                        "strokeWidth":  1
                                                                                    },
                                                                           "encoding":  {
